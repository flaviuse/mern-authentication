{
  "name": "server",
  "version": "1.0.0",
  "description": "Server for MERN auth",
  "private": true,
  "author": "Flavien Rebattet",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "ts-node-dev --respawn -r tsconfig-paths/register index.ts",
    "start": "yarn build && node build/index.js",
    "start:prod": "node build/index.js",
    "ci": "yarn install --frozen-lockfile"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "compression": "^1.7.4",
    "connect-mongo": "^4.6.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.20",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.11.2",
    "express-session": "^1.19.0",
    "helmet": "^5.1.1",
    "joi": "^18.2.1",
    "joi-objectid": "^4.0.2",
    "moment": "^2.30.1",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^6.13.9",
    "passport": "0.4.1",
    "passport-local": "^1.0.0",
    "ramda": "^0.32.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "1.7.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/mongo-sanitize": "^1.0.3",
    "@types/node": "22.19.18",
    "@types/passport": "1.0.7",
    "@types/passport-local": "1.0.34",
    "@types/ramda": "^0.30.2",
    "@types/winston": "^2.4.4",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^4.9.5"
  },
  "resolutions": {
    "@types/passport": "1.0.7"
  }
}
